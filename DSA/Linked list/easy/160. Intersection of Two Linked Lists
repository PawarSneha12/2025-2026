160. Intersection of Two Linked Lists

public class Solution {
    public ListNode getIntersectionNode(ListNode headA, ListNode headB) {

        int l1=0;
        int l2=0;
        int diff=0;
        ListNode temp=headA;
        while(temp!=null){
            l1++;
            temp=temp.next;
        }
        temp=headB;
        while(temp!=null){
            l2++;
            temp=temp.next;
        }
        temp=headA;
       ListNode temp2=headB;
        if(l1!=l2){
            if(l1>l2){
           diff=l1-l2;
           while(diff>0){
            temp=temp.next;
            diff--;
           }
            }
            else{
                diff=l2-l1;
                while(diff>0){
                    temp2=temp2.next;
                    diff--;
                }
            }
        }
        while(temp!=null&&temp2!=null){
            if(temp==temp2){
                return temp;
            }
            temp=temp.next;
            temp2=temp2.next;
        }

        return null;
    }
}
