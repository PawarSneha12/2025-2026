21. Merge Two Sorted Lists


class Solution {
    public ListNode mergeTwoLists(ListNode list1, ListNode list2) {
ListNode list =new ListNode(-1);
ListNode temp=list;
while(list1!=null&&list2!=null){
    if(list1.val<list2.val){
     ListNode newNode =new ListNode(list1.val);
     list.next=newNode;
     list= list.next;
     list1=list1.next;
    }
    else{
        ListNode newNode=new ListNode(list2.val);
        list.next=newNode;
        list= list.next;
        list2=list2.next;
    }
}
while(list1!=null){
    ListNode newNode =new ListNode(list1.val);
     list.next=newNode;
     list= list.next;
     list1=list1.next;
}
while(list2!=null){
    ListNode newNode =new ListNode(list2.val);
     list.next=newNode;
     list= list.next;
     list2=list2.next;
}
    return temp.next;    
    }
}
