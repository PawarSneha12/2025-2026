83. Remove Duplicates from Sorted List

class Solution {
    public ListNode deleteDuplicates(ListNode head) {
        if(head==null||head.next==null){
            return head;
        }

        ListNode w=head;
        ListNode r=head.next;
        while(r!=null){
            if(w.val==r.val){
                r=r.next;
            }
            else{
                w.next=r;
                w=w.next;
                r=r.next;
            }
        }
        w.next=null;
        return head;
    }
}
