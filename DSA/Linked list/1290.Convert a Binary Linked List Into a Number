1290. Convert Binary Number in a Linked List to Integer

class Solution {
    public int getDecimalValue(ListNode head) {
        int ans=0;
       //first logic
       /* while(head!=null){
         ans=ans*2+head.val;
         head=head.next;
        }
        */
     while(head!=null){
        ans=(ans<<1)|head.val;
        head=head.next;
     }
        return ans;
    }
}
