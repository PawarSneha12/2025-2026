Give a linked list;

they asked as you insert at end of the Linked List.


class Solution {
    public Node insertAtEnd(Node head, int x) {
        // code here
        Node Nd=new Node(x);
        if(head==null){
            head=Nd;
            return head;
        }
        Node n=head;
        while(n.next!=null){
            n=n.next;
        }
        n.next=Nd;
        return head;
    }
}
